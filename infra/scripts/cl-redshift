import sys
import time
from datetime import datetime, timedelta

from awsglue.utils import getResolvedOptions
from awsglue.context import GlueContext
from awsglue.dynamicframe import DynamicFrame
from awsglue.job import Job

from pyspark import StorageLevel
from pyspark.context import SparkContext
from pyspark.sql import Window
from pyspark.sql.functions import (
    col,
    lit,
    when,
    to_json,
    get_json_object,
    current_timestamp,
    trim,
    row_number,
    sha2,
    struct
)
from pyspark.sql.types import (
    StructType,
    ArrayType,
    MapType,
    StringType,
    NullType,
    TimestampType
)


# Exact Redshift column order
ALL_TARGET_COLUMNS = [
    "accountid",
    "categories",
    "channel",
    "contentmetadata",
    "conversationcharacteristics",
    "custommodels",
    "customermetadata",
    "jobstatus",
    "languagecode",
    "participants",
    "transcript",
    "version",
    "source_file",
    "contact_id",
    "processed_at",
    "year",
    "month",
    "day"
]

# Columns written to Redshift SUPER fields
SUPER_TARGET_COLUMNS = [
    "categories",
    "contentmetadata",
    "conversationcharacteristics",
    "custommodels",
    "customermetadata",
    "participants",
    "transcript"
]

# Columns written to Redshift VARCHAR fields
STRING_TARGET_COLUMNS = [
    "accountid",
    "channel",
    "jobstatus",
    "languagecode",
    "version",
    "source_file",
    "contact_id",
    "year",
    "month",
    "day"
]

# Safe fields allowed in CloudWatch samples
SAFE_SAMPLE_COLUMNS = [
    "accountid",
    "channel",
    "jobstatus",
    "languagecode",
    "version",
    "source_file",
    "contact_id",
    "processed_at",
    "year",
    "month",
    "day"
]


def get_optional_arg(arg_name, default_value):
    """Read an optional Glue argument."""
    for index, argument in enumerate(sys.argv):
        if argument == f"--{arg_name}" and index + 1 < len(sys.argv):
            return sys.argv[index + 1]
    return default_value


def get_optional_bool(arg_name, default_value=False):
    """Read an optional Boolean Glue argument."""
    default_text = "true" if default_value else "false"
    value = get_optional_arg(arg_name, default_text).strip().lower()

    if value not in {"true", "false"}:
        raise ValueError(f"{arg_name} must be true or false.")

    return value == "true"


def build_redshift_tmp_dir(bucket_value):
    """Build the temporary S3 path used by Redshift COPY."""
    value = bucket_value.strip().replace("s3://", "").rstrip("/")

    if "/" in value:
        return f"s3://{value}/"

    return f"s3://{value}/redshift_temp/"


def build_partition_predicate(lookback_days):
    """Build a year/month/day predicate for recent partitions."""
    if lookback_days < 0:
        raise ValueError("lookback_days cannot be negative.")

    today = datetime.now().date()
    conditions = []

    for days_ago in range(lookback_days + 1):
        partition_date = today - timedelta(days=days_ago)
        conditions.append(
            "("
            f"year = '{partition_date.year}' "
            f"AND month = '{partition_date.month:02d}' "
            f"AND day = '{partition_date.day:02d}'"
            ")"
        )

    return "(" + " OR ".join(conditions) + ")"


def log_section(title):
    print(f"\n===== {title} =====")


def log_elapsed(stage_name, start_time):
    elapsed = time.perf_counter() - start_time
    print(f"{stage_name} completed in {elapsed:.2f} seconds.")


def log_safe_sample(dataframe, title, row_count=10):
    """Show only non-sensitive operational fields."""
    selected_columns = [
        name for name in SAFE_SAMPLE_COLUMNS
        if name in dataframe.columns
    ]

    log_section(title)

    if selected_columns:
        dataframe.select(*selected_columns).show(
            row_count,
            truncate=False
        )
    else:
        print("No safe sample columns are available.")


def transform_source_dataframe(source_df):
    """Normalise source fields and prepare JSON values."""
    original_columns = list(source_df.columns)
    lowercase_columns = [name.lower() for name in original_columns]

    if len(lowercase_columns) != len(set(lowercase_columns)):
        raise ValueError(
            "Lowercasing source columns would create duplicates."
        )

    # Rename all top-level columns in one operation.
    spark_df = source_df.toDF(*lowercase_columns)

    # Extract ContactId and InputS3Uri from CustomerMetadata.
    if "customermetadata" in spark_df.columns:
        metadata_type = spark_df.schema["customermetadata"].dataType

        if isinstance(metadata_type, StructType):
            spark_df = (
                spark_df
                .withColumn(
                    "contact_id",
                    col("customermetadata.ContactId").cast(StringType())
                )
                .withColumn(
                    "source_file",
                    col("customermetadata.InputS3Uri").cast(StringType())
                )
            )

        elif isinstance(metadata_type, StringType):
            spark_df = (
                spark_df
                .withColumn(
                    "contact_id",
                    get_json_object(
                        col("customermetadata"),
                        "$.ContactId"
                    )
                )
                .withColumn(
                    "source_file",
                    get_json_object(
                        col("customermetadata"),
                        "$.InputS3Uri"
                    )
                )
            )

        else:
            print(
                "WARNING: customermetadata has unsupported type: "
                f"{metadata_type}."
            )
            spark_df = (
                spark_df
                .withColumn("contact_id", lit(None).cast(StringType()))
                .withColumn("source_file", lit(None).cast(StringType()))
            )

    else:
        print("WARNING: customermetadata is missing from the source.")
        spark_df = (
            spark_df
            .withColumn("contact_id", lit(None).cast(StringType()))
            .withColumn("source_file", lit(None).cast(StringType()))
        )

    spark_df = spark_df.withColumn(
        "processed_at",
        current_timestamp()
    )

    # Ensure SUPER values are JSON strings or SQL NULL.
    schema_types = {
        field.name: field.dataType
        for field in spark_df.schema.fields
    }

    for column_name in SUPER_TARGET_COLUMNS:
        if column_name not in spark_df.columns:
            continue

        column_type = schema_types[column_name]

        if isinstance(column_type, NullType):
            spark_df = spark_df.withColumn(
                column_name,
                lit(None).cast(StringType())
            )

        elif isinstance(column_type, (StructType, ArrayType, MapType)):
            spark_df = spark_df.withColumn(
                column_name,
                when(
                    col(column_name).isNull(),
                    lit(None).cast(StringType())
                ).otherwise(to_json(col(column_name)))
            )

        elif isinstance(column_type, StringType):
            spark_df = spark_df.withColumn(
                column_name,
                when(
                    col(column_name).isNull()
                    | (trim(col(column_name)) == ""),
                    lit(None).cast(StringType())
                ).otherwise(col(column_name).cast(StringType()))
            )

        else:
            print(
                f"WARNING: {column_name} has unsupported type "
                f"{column_type}. Storing it as NULL."
            )
            spark_df = spark_df.withColumn(
                column_name,
                lit(None).cast(StringType())
            )

    return spark_df


def align_target_schema(spark_df):
    """Add missing columns and enforce Redshift-compatible types."""
    existing_columns = set(spark_df.columns)

    for column_name in ALL_TARGET_COLUMNS:
        if column_name in existing_columns:
            continue

        if column_name == "processed_at":
            spark_df = spark_df.withColumn(
                column_name,
                current_timestamp()
            )
        else:
            spark_df = spark_df.withColumn(
                column_name,
                lit(None).cast(StringType())
            )

    for column_name in SUPER_TARGET_COLUMNS:
        spark_df = spark_df.withColumn(
            column_name,
            col(column_name).cast(StringType())
        )

    for column_name in STRING_TARGET_COLUMNS:
        spark_df = spark_df.withColumn(
            column_name,
            col(column_name).cast(StringType())
        )

    spark_df = spark_df.withColumn(
        "processed_at",
        col("processed_at").cast(TimestampType())
    )

    # Convert blank ContactIds to SQL NULL.
    spark_df = spark_df.withColumn(
        "contact_id",
        when(
            col("contact_id").isNull()
            | (trim(col("contact_id")) == ""),
            lit(None).cast(StringType())
        ).otherwise(trim(col("contact_id")))
    )

    return spark_df


def remove_duplicate_contact_ids(valid_df):
    """Deterministically keep one row per ContactId in this batch."""
    valid_df = valid_df.withColumn(
        "__row_hash",
        sha2(
            to_json(
                struct(
                    *[col(name) for name in ALL_TARGET_COLUMNS]
                )
            ),
            256
        )
    )

    duplicate_window = (
        Window
        .partitionBy("contact_id")
        .orderBy(
            col("year").desc_nulls_last(),
            col("month").desc_nulls_last(),
            col("day").desc_nulls_last(),
            col("source_file").desc_nulls_last(),
            col("__row_hash").desc_nulls_last()
        )
    )

    return (
        valid_df
        .withColumn(
            "__duplicate_row_number",
            row_number().over(duplicate_window)
        )
        .filter(col("__duplicate_row_number") == 1)
        .drop("__duplicate_row_number", "__row_hash")
    )


def main():
    total_job_start = time.perf_counter()

    args = getResolvedOptions(
        sys.argv,
        [
            "JOB_NAME",
            "source_table",
            "source_database",
            "target_table",
            "target_connection_name",
            "job_store_bucket_name",
            "redshift_s3_role_arn"
        ]
    )

    spark_context = SparkContext()
    glue_context = GlueContext(spark_context)
    job = Job(glue_context)
    job.init(args["JOB_NAME"], args)

    target_table = args["target_table"]
    staging_table = "public.contact_lens_staging_temp"
    redshift_tmp_dir = build_redshift_tmp_dir(
        args["job_store_bucket_name"]
    )

    try:
        lookback_days = int(
            get_optional_arg("lookback_days", "1")
        )
    except ValueError as error:
        raise ValueError(
            "lookback_days must be a valid integer."
        ) from error

    initial_load = get_optional_bool("initial_load", False)
    detailed_metrics = get_optional_bool(
        "enable_detailed_metrics",
        False
    )
    sample_logging = get_optional_bool(
        "enable_sample_logging",
        False
    )

    log_section("CONTACT LENS REDSHIFT ETL STARTED")
    print(f"Job name: {args['JOB_NAME']}")
    print(f"Source: {args['source_database']}.{args['source_table']}")
    print(f"Target table: {target_table}")
    print(f"Staging table: {staging_table}")
    print(f"Initial load: {initial_load}")
    print(f"Lookback days: {lookback_days}")
    print(f"Detailed metrics: {detailed_metrics}")
    print(f"Sample logging: {sample_logging}")

    # Read only recent partitions during scheduled runs.
    catalog_read_start = time.perf_counter()

    if initial_load:
        print("Performing full Contact Lens load.")
        source_dyf = glue_context.create_dynamic_frame.from_catalog(
            database=args["source_database"],
            table_name=args["source_table"],
            transformation_ctx="source_dyf"
        )
    else:
        predicate = build_partition_predicate(lookback_days)
        print("Performing incremental Contact Lens load.")
        print(f"Predicate: {predicate}")

        source_dyf = glue_context.create_dynamic_frame.from_catalog(
            database=args["source_database"],
            table_name=args["source_table"],
            push_down_predicate=predicate,
            transformation_ctx="source_dyf"
        )

    source_df = source_dyf.toDF()
    log_elapsed("Glue Catalog read setup", catalog_read_start)

    log_section("SOURCE DATAFRAME SCHEMA")
    source_df.printSchema()

    # isEmpty avoids a full source count in normal production runs.
    if source_df.isEmpty():
        print(
            "No source records were found for the selected partitions. "
            "Redshift will not be updated."
        )
        job.commit()
        log_elapsed("Total ETL job", total_job_start)
        return

    if detailed_metrics:
        metric_start = time.perf_counter()
        source_record_count = source_df.count()
        print(f"Source records read: {source_record_count}")
        log_elapsed("Source count", metric_start)

    transformation_start = time.perf_counter()

    prepared_df = align_target_schema(
        transform_source_dataframe(source_df)
    )

    log_section("PREPARED DATAFRAME SCHEMA")
    prepared_df.printSchema()

    if detailed_metrics:
        valid_before_dedup_df = (
            prepared_df
            .filter(col("contact_id").isNotNull())
            .persist(StorageLevel.MEMORY_AND_DISK)
        )

        valid_before_dedup_count = valid_before_dedup_df.count()
        missing_contact_id_count = (
            prepared_df
            .filter(col("contact_id").isNull())
            .count()
        )

        print(
            "Records removed because contact_id was missing or blank: "
            f"{missing_contact_id_count}"
        )
        print(
            "Valid records before deduplication: "
            f"{valid_before_dedup_count}"
        )

        dedup_source_df = valid_before_dedup_df
    else:
        valid_before_dedup_df = None
        dedup_source_df = prepared_df.filter(
            col("contact_id").isNotNull()
        )

    # Persist only the final expensive result.
    valid_df = (
        remove_duplicate_contact_ids(dedup_source_df)
        .select(*ALL_TARGET_COLUMNS)
        .persist(StorageLevel.MEMORY_AND_DISK)
    )

    valid_record_count = valid_df.count()

    if detailed_metrics:
        duplicate_count = (
            valid_before_dedup_count - valid_record_count
        )
        print(f"Duplicate records removed: {duplicate_count}")

    print(
        "Valid deduplicated records to load into staging: "
        f"{valid_record_count}"
    )

    log_elapsed("Transformation and deduplication", transformation_start)

    if valid_before_dedup_df is not None:
        valid_before_dedup_df.unpersist()

    if valid_record_count == 0:
        valid_df.unpersist()
        print(
            "No valid records remain after ContactId validation. "
            "Redshift will not be updated."
        )
        job.commit()
        log_elapsed("Total ETL job", total_job_start)
        return

    log_section("FINAL REDSHIFT DATAFRAME SCHEMA")
    valid_df.printSchema()

    if sample_logging:
        log_safe_sample(
            valid_df,
            "SAFE SAMPLE BEFORE REDSHIFT WRITE"
        )

    final_dyf = DynamicFrame.fromDF(
        valid_df,
        glue_context,
        "final_redshift_frame"
    )

    # Clear only staging, then insert new ContactIds into target.
    preactions = f"""
    TRUNCATE TABLE {staging_table};
    """

    postactions = f"""
    BEGIN;

    INSERT INTO {target_table} (
        accountid,
        categories,
        channel,
        contentmetadata,
        conversationcharacteristics,
        custommodels,
        customermetadata,
        jobstatus,
        languagecode,
        participants,
        transcript,
        version,
        source_file,
        contact_id,
        processed_at,
        year,
        month,
        day
    )
    SELECT
        s.accountid,
        s.categories,
        s.channel,
        s.contentmetadata,
        s.conversationcharacteristics,
        s.custommodels,
        s.customermetadata,
        s.jobstatus,
        s.languagecode,
        s.participants,
        s.transcript,
        s.version,
        s.source_file,
        s.contact_id,
        s.processed_at,
        s.year,
        s.month,
        s.day
    FROM {staging_table} AS s
    WHERE s.contact_id IS NOT NULL
      AND NOT EXISTS (
          SELECT 1
          FROM {target_table} AS t
          WHERE t.contact_id = s.contact_id
      );

    COMMIT;
    """

    log_section("REDSHIFT LOAD STARTED")
    print(f"Records being sent to staging: {valid_record_count}")

    redshift_write_start = time.perf_counter()

    try:
        glue_context.write_dynamic_frame.from_options(
            frame=final_dyf,
            connection_type="redshift",
            connection_options={
                "redshiftTmpDir": redshift_tmp_dir,
                "aws_iam_role": args["redshift_s3_role_arn"],
                "useConnectionProperties": "true",
                "connectionName": args["target_connection_name"],
                "dbtable": staging_table,
                "preactions": preactions,
                "postactions": postactions,
                "extracopyoptions": "ACCEPTINVCHARS"
            },
            transformation_ctx="AmazonRedshiftTarget"
        )
    finally:
        valid_df.unpersist()

    log_elapsed(
        "Redshift staging load and target insert",
        redshift_write_start
    )

    job.commit()
    log_elapsed("Total ETL job", total_job_start)
    log_section("CONTACT LENS REDSHIFT ETL COMPLETED")


if __name__ == "__main__":
    main()
