        value_or_null(
            source_df,
            "ContactId",
            "string",
        ) == DEBUG_CONTACT_ID
    ).select(
        value_or_null(
            source_df,
            "ContactId",
            "string",
        ).alias("contact_id"),
        value_or_null(
            source_df,
            "LastUpdateTimestamp",
            "string",
        ).alias("last_update_timestamp"),
        json_text_or_null(
            source_df,
            "Agent",
        ).alias("agent_source_json"),
        json_text_or_null(
            source_df,
            "Queue",
        ).alias("queue_source_json"),
        col("_source_file").alias("source_file"),
    ).orderBy(
        "last_update_timestamp",
        "source_file",
    ).show(
        200,
        truncate=False,
    )


