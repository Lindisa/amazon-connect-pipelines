def get_optional_job_arg(argument_name: str, default_value: str = "") -> str:
    flag = f"--{argument_name}"
    if flag not in sys.argv:
        return default_value

    index = sys.argv.index(flag)
    if index + 1 >= len(sys.argv):
        return default_value

    return sys.argv[index + 1]



