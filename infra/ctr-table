SELECT
    f.contact_id,
    f.agent_arn AS flattened_agent_arn,
    c.ctr_agent_arn,
    f.queue_arn AS flattened_queue_arn,
    c.ctr_queue_arn
FROM public.ctr_flattened f
JOIN (
    SELECT
        contact_id,
        ctr_agent_arn,
        ctr_queue_arn
    FROM (
        SELECT
            contact_id,
            JSON_EXTRACT_PATH_TEXT(
                JSON_SERIALIZE(agent),
                'ARN',
                true
            ) AS ctr_agent_arn,
            JSON_EXTRACT_PATH_TEXT(
                JSON_SERIALIZE(queue),
                'ARN',
                true
            ) AS ctr_queue_arn,
            ROW_NUMBER() OVER (
                PARTITION BY contact_id
                ORDER BY last_update_timestamp DESC
            ) AS rn
        FROM public.ctr
    ) ranked_ctr
    WHERE rn = 1
) c
    ON c.contact_id = f.contact_id
WHERE
    (
        f.agent_arn IS NULL
        AND NULLIF(TRIM(c.ctr_agent_arn), '') IS NOT NULL
    )
    OR
    (
        f.queue_arn IS NULL
        AND NULLIF(TRIM(c.ctr_queue_arn), '') IS NOT NULL
    );



    SELECT
        contact_id,
        last_update_timestamp,
        JSON_EXTRACT_PATH_TEXT(
            JSON_SERIALIZE(agent),
            'ARN',
            true
        ) AS ctr_agent_arn,
        JSON_EXTRACT_PATH_TEXT(
            JSON_SERIALIZE(queue),
            'ARN',
            true
        ) AS ctr_queue_arn,
        ROW_NUMBER() OVER (
            PARTITION BY contact_id
            ORDER BY last_update_timestamp DESC
        ) AS row_num
    FROM public.ctr
)
SELECT
    f.contact_id,
    f.agent_arn AS flattened_agent_arn,
    c.ctr_agent_arn,
    f.queue_arn AS flattened_queue_arn,
    c.ctr_queue_arn
FROM public.ctr_flattened f
JOIN latest_ctr c
    ON c.contact_id = f.contact_id
   AND c.row_num = 1
WHERE
    (
        f.agent_arn IS NULL
        AND NULLIF(TRIM(c.ctr_agent_arn), '') IS NOT NULL
    )
    OR
    (
        f.queue_arn IS NULL
        AND NULLIF(TRIM(c.ctr_queue_arn), '') IS NOT NULL
    );






SELECT
    f.contact_id,
    f.last_update_timestamp AS flattened_timestamp,
    MAX(c.last_update_timestamp) AS latest_ctr_timestamp
FROM public.ctr_flattened f
JOIN public.ctr c
    ON c.contact_id = f.contact_id
GROUP BY
    f.contact_id,
    f.last_update_timestamp
HAVING f.last_update_timestamp <> MAX(c.last_update_timestamp);





